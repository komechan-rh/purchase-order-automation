{
  "name": "purchase-orderautomation-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run clean && tsc -p tsconfig.json && cp appsscript.json dist/appsscript.json",
